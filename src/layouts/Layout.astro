---
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/700.css";
import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "../styles/global.css";
import GlobalHeader from "../components/GlobalHeader.astro";
import { useTranslations } from "../i18n/utils";

interface Props {
    title?: string;
    lang?: "es" | "en";
}

const { title: propTitle } = Astro.props;
const lang = Astro.params.lang as "es" | "en" || "es";
const t = useTranslations(lang);

const title = propTitle ? `${propTitle} | Spoonergy` : "Spoonergy";
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        
        <title>{title}</title>
        <meta name="title" content={title} />
        <meta name="description" content={t('hero.description')} />
        <meta name="theme-color" content="#000000" />

        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://spoonergy.com/" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={t('hero.description')} />
        <meta property="og:image" content="/og-preview.png" />

        <link rel="icon" type="image/png" href="/favicon-small.png" />
        <link rel="apple-touch-icon" href="/favicon-small.png" />
        <link rel="manifest" href="/manifest.json" />
        
        <link rel="canonical" href={`https://spoonergy.com/${lang}/`} />
    </head>
    <body
        class="relative min-h-screen selection:bg-zinc-800 selection:text-zinc-50"
    >
        <!-- Global Noise Overlay -->
        <div
            id="global-noise"
            class="pointer-events-none fixed inset-0 z-[40] h-full w-full opacity-[0.04] mix-blend-overlay hidden md:block"
            style="background-image: url('/noise.webp');"
        >
        </div>
 
        <!-- Custom Spotlight Cursor -->
        <div
            id="spotlight"
            class="pointer-events-none fixed inset-0 z-[90] transition-opacity duration-300 opacity-0 bg-[radial-gradient(circle_400px_at_var(--x,_50vw)_var(--y,_50vh),rgba(255,255,255,0.06),transparent_80%)] hidden md:block"
        >
        </div>

        <!-- MANUAL REACT ROOTS (No Astro Islands) -->
        <div id="modal-root"></div>
        
        <GlobalHeader lang={lang} />

        <slot />

        <!-- Store language for the script to read -->
        <meta name="page-lang" content={lang} />

        <script>
            // --- ATOMIC INTERACTIVITY SCRIPT (THE ONLY JS RUNNING ON LOAD) ---
            
            const getLang = () => {
                const meta = document.querySelector('meta[name="page-lang"]');
                return meta ? meta.getAttribute('content') : 'es';
            };

            // 1. Reveal on scroll logic (Consolidated)
            const setupReveals = () => {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('visible');
                        }
                    });
                }, { threshold: 0.1 });

                document.querySelectorAll('.reveal-on-scroll, .reveal-text-container').forEach(el => observer.observe(el));
            };

            // 2. Manual Hydration Signal
            let hasHydrated = false;
            let hydrationPromise = null;

            const startHydration = async () => {
                if (hydrationPromise) return hydrationPromise;
                
                hydrationPromise = (async () => {
                    hasHydrated = true;
                    try {
                        const { hydrateSpoon, hydrateModal } = await import('../scripts/manual-hydrate.tsx');
                        const lang = getLang();
                        hydrateSpoon();
                        hydrateModal(lang as 'es' | 'en');
                        return true;
                    } catch (error) {
                        console.error("Hydration failed:", error);
                        hasHydrated = false;
                        hydrationPromise = null;
                        return false;
                    }
                })();
                
                return hydrationPromise;
            };

            // Global listener for checkout to ensure hydration happens
            window.addEventListener('open-checkout', async (e) => {
                if (!hasHydrated) {
                    await startHydration();
                    // Small delay to let React components mount and register their listeners
                    setTimeout(() => {
                        window.dispatchEvent(new CustomEvent('open-checkout'));
                    }, 50);
                }
            }, { capture: true });

            // 3. Lenis & Scroll Prep
            const initCore = async () => {
                try {
                    const { default: Lenis } = await import('lenis');
                    const lenis = new Lenis({ lerp: 0.05 });
                    
                    function raf(time: number) {
                        lenis.raf(time);
                        requestAnimationFrame(raf);
                    }
                    requestAnimationFrame(raf);

                    // Re-bind anchors
                    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
                        anchor.addEventListener("click", (e) => {
                            e.preventDefault();
                            const targetId = anchor.getAttribute("href");
                            if (targetId && targetId !== "#") {
                                const target = document.querySelector(targetId);
                                if (target) lenis.scrollTo(target, { duration: 2 });
                            }
                        });
                    });
                } catch (error) {
                    console.error("Lenis init failed:", error);
                }
            };

            // Spotlight effect (Only for mouse)
            const spotlight = document.getElementById("spotlight");
            if (spotlight) {
                window.addEventListener("mousemove", (e) => {
                    spotlight.style.opacity = "1";
                    spotlight.style.setProperty("--x", `${e.clientX}px`);
                    spotlight.style.setProperty("--y", `${e.clientY}px`);
                }, { passive: true });
            }

            // --- THE TRIGGER SEQUENCE ---
            window.addEventListener('spoonergy-ready', () => {
                setupReveals();
                initCore();
                
                // Fallback hydration after 10s of being ready
                setTimeout(startHydration, 10000);
            }, { once: true });

            // User triggers hydration immediately
            const triggerEvents = ['scroll', 'touchstart', 'mousedown', 'keydown', 'wheel'];
            const handleInteraction = () => {
                startHydration();
                triggerEvents.forEach(evt => window.removeEventListener(evt, handleInteraction));
            };
            
            triggerEvents.forEach(evt => window.addEventListener(evt, handleInteraction, { once: true, passive: true }));
        </script>
    </body>
</html>
