---
import Layout from "../../layouts/Layout.astro";
import PreloaderAstro from "../../components/PreloaderAstro.astro";
import { DeferredSpoon } from "../../components/DeferredSpoon";
import HeroSection from "../../components/HeroSection.astro";
import TransitionSection from "../../components/TransitionSection.astro";
import BenefitsSection from "../../components/BenefitsSection.astro";
import TechSection from "../../components/TechSection.astro";
import DesignSection from "../../components/DesignSection.astro";
import OrigenSection from "../../components/OrigenSection.astro";
import ExperienciaSection from "../../components/ExperienciaSection.astro";
import TestimoniosSection from "../../components/TestimoniosSection.astro";
import FAQSection from "../../components/FAQSection.astro";
import CTASection from "../../components/CTASection.astro";

export function getStaticPaths() {
	return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const { lang } = Astro.params as { lang: "es" | "en" };

// Switch para activar o desactivar temporalmente el loader y el thumbnail
const ENABLE_PRELOADER = false;
---

<Layout lang={lang}>
	{ENABLE_PRELOADER && <PreloaderAstro lang={lang} />}

	<!-- Placed before main so it natively renders UNDER main by DOM order (Parallax Curtain) -->
	<CTASection lang={lang} />

	<!-- No z-index trapping on main, allowing internal z-[60] text to globally overlap TheSpoon z-[50] -->
	<main
		class="relative z-[100] bg-transparent shadow-[0_20px_50px_rgba(0,0,0,0.5)] mb-[100vh]"
	>
		<div class="grid w-full grid-cols-1">
			<!-- Capa Base: Fondo Negro Stick y WebGL (z-0 a z-10) -->
			<!-- Al usar Grid, se superpone perfectamente sin márgenes negativos que causen CLS -->
			<div class="col-start-1 row-start-1 w-full h-full pointer-events-none">
				<div
					class="sticky top-0 left-0 w-full h-[100vh] z-0 bg-black pointer-events-auto"
				>
					<!-- Imagen de póster LCP siempre visible inicialmente -->
					<div
						id="lcp-poster"
						class="absolute inset-0 flex items-center justify-center z-0 pointer-events-none"
					>
						<img
							src="/spoon-placeholder.webp"
							alt="Spoonergy"
							fetchpriority="high"
							class="w-[750px] pb-20 h-auto object-contain opacity-100"
						/>
					</div>

					<!-- La capa de React Three Fiber cargada al cargar la página para asegurar aparición automática -->
					<DeferredSpoon client:load loadInstantly={!ENABLE_PRELOADER} />

					<script is:inline>
						const handleSpoonLoaded = () => {
							const poster = document.getElementById("lcp-poster");
							if (poster) {
								poster.style.transition = "opacity 0.3s ease-out";
								poster.style.opacity = "0";
								setTimeout(() => {
									if (poster.parentElement) poster.remove();
								}, 300);
							}
							window.removeEventListener("spoon-loaded", handleSpoonLoaded);
						};
						window.addEventListener("spoon-loaded", handleSpoonLoaded);
					</script>
				</div>
			</div>

			<!-- Capa Superior: Interfaz de Usuario (z-20) -->
			<div class="col-start-1 row-start-1 relative z-20">
				<HeroSection lang={lang} />
				<TransitionSection lang={lang} />
				<BenefitsSection lang={lang} />
				<TechSection lang={lang} />
				<DesignSection lang={lang} />
				<OrigenSection lang={lang} />
				<ExperienciaSection lang={lang} />
				<TestimoniosSection lang={lang} />
				<FAQSection lang={lang} />
			</div>
		</div>
	</main>
</Layout>
