---
// src/components/GlobalHeader.astro
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header
  id="global-header"
  class="fixed top-0 left-0 w-full z-[200] transition-all duration-500 ease-in-out py-6 px-4 md:px-10 flex justify-center pointer-events-auto"
>
  <div
    id="header-nav"
    class="w-full max-w-6xl flex items-center justify-between transition-all duration-500 ease-out rounded-full border border-transparent"
  >
    <!-- Left: Logo -->
    <div class="w-1/3 flex justify-start pl-2">
      <a
        href={`/${lang}/`}
        class="font-sans font-medium tracking-[0.2em] text-xs text-zinc-100 uppercase hover:text-white transition-opacity duration-300"
      >
        SPOONERGY™
      </a>
    </div>

    <!-- Center: Links -->
    <nav class="hidden md:flex w-1/3 justify-center gap-8">
      <a
        href="#overview"
        class="text-xs font-sans text-zinc-400 hover:text-zinc-50 transition-colors tracking-wide"
        >{t('nav.overview')}</a
      >
      <a
        href="#how-it-works"
        class="text-xs font-sans text-zinc-400 hover:text-zinc-50 transition-colors tracking-wide"
        >{t('nav.how-it-works')}</a
      >
      <a
        href="#design"
        class="text-xs font-sans text-zinc-400 hover:text-zinc-50 transition-colors tracking-wide"
        >{t('nav.design')}</a
      >
      <a
        href="#questions"
        class="text-xs font-sans text-zinc-400 hover:text-zinc-50 transition-colors tracking-wide"
        >{t('nav.questions')}</a
      >
    </nav>

    <!-- Right: CTA + Language Switcher -->
    <div class="w-1/3 flex items-center justify-end gap-6 pr-2">
      <!-- Language Switcher -->
      <div class="flex items-center gap-3 font-mono text-[10px] tracking-widest uppercase">
        <a 
          href="/es/" 
          class={lang === 'es' ? 'text-white' : 'text-zinc-600 hover:text-zinc-400 transition-colors'}
        >ES</a>
        <span class="text-zinc-800">/</span>
        <a 
          href="/en/" 
          class={lang === 'en' ? 'text-white' : 'text-zinc-600 hover:text-zinc-400 transition-colors'}
        >EN</a>
      </div>

      <a
        id="header-buy-button"
        href="#buy"
        class="relative flex items-center justify-center bg-gradient-to-b from-zinc-50 to-zinc-300 text-zinc-950 font-sans tracking-wide text-xs px-6 py-[0.45rem] rounded-full truncate transition-all duration-500 ease-out shadow-[0_0_15px_rgba(255,255,255,0.15)] hover:shadow-[0_0_30px_rgba(255,255,255,0.7),0_0_60px_rgba(226,226,213,0.4)] hover:scale-105 hover:-translate-y-[2px] overflow-hidden group ring-1 ring-white/50 hover:ring-white"
      >
        <!-- Interactive internal shine sweep -->
        <span
          class="absolute top-0 left-0 w-[150%] h-full bg-gradient-to-r from-transparent via-white to-transparent skew-x-[-30deg] -translate-x-[150%] group-hover:translate-x-[150%] group-hover:transition-transform group-hover:duration-[1200ms] group-hover:ease-in-out pointer-events-none"
        ></span>
        <span
          class="relative z-10 font-bold uppercase tracking-widest drop-shadow-sm"
          >{t('nav.buy')}</span
        >
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("global-header");
  const nav = document.getElementById("header-nav");

  if (header && nav) {
    const handleScroll = () => {
      if (window.scrollY > 40) {
        header.classList.remove("py-6", "px-4", "md:px-10");
        header.classList.add("py-4", "px-4");

        nav.classList.add(
          "bg-zinc-900/30",
          "backdrop-blur-xl",
          "border-zinc-700/40",
          "py-3",
          "px-5",
          "shadow-[0_8px_32px_rgba(0,0,0,0.2)]",
        );
        nav.classList.remove("border-transparent");
      } else {
        header.classList.add("py-6", "px-4", "md:px-10");
        header.classList.remove("py-4", "px-4");

        nav.classList.remove(
          "bg-zinc-900/30",
          "backdrop-blur-xl",
          "border-zinc-700/40",
          "py-3",
          "px-5",
          "shadow-[0_8px_32px_rgba(0,0,0,0.2)]",
        );
        nav.classList.add("border-transparent");
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();

    // Smooth Scroll to Center Logic
    const navLinks = document.querySelectorAll(
      'nav a, #header-nav a[href^="#"]',
    );
    navLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        const targetId = link.getAttribute("href");
        if (targetId && targetId.startsWith("#")) {
          e.preventDefault();
          const targetElement = document.querySelector(targetId);
          if (targetElement) {
            targetElement.scrollIntoView({
              behavior: "smooth",
              block: "center",
            });
          }
        }
      });
    });

    // Open Checkout Modal
    const headerBuyBtn = document.getElementById("header-buy-button");
    if (headerBuyBtn) {
      headerBuyBtn.addEventListener("click", (e) => {
        e.preventDefault();
        window.dispatchEvent(new CustomEvent("open-checkout"));
      });
    }
  }
</script>
