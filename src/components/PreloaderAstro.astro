---
import { ui } from '../i18n/ui';

interface Props {
    lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = (key: keyof typeof ui['es']) => ui[lang][key] || ui['es'][key];

const phrases = [
    t('preloader.1'),
    t('preloader.2'),
    t('preloader.3'),
    t('preloader.4')
];
---

<div id="native-preloader" class="fixed inset-0 z-[1000] flex items-center justify-center pointer-events-auto bg-transparent">
    <!-- Curtain Panels -->
    <div id="preloader-panel-top" class="absolute top-0 left-0 w-full h-[50vh] bg-black z-[-1] transition-transform duration-[1200ms] ease-[cubic-bezier(0.77,0,0.175,1)]"></div>
    <div id="preloader-panel-bottom" class="absolute bottom-0 left-0 w-full h-[50vh] bg-black z-[-1] transition-transform duration-[1200ms] ease-[cubic-bezier(0.77,0,0.175,1)]"></div>

    <!-- Content Layer -->
    <div id="preloader-content" class="flex flex-col items-center gap-12 transition-all duration-800">
        
        <!-- Abstract Symbol: Pulsing Ring -->
        <div class="relative w-24 h-24 flex items-center justify-center">
            <div class="absolute inset-0 border border-white/20 rounded-full animate-pulse-ring-1"></div>
            <div class="absolute inset-2 border border-white/40 rounded-full animate-pulse-ring-2"></div>
            <div class="w-1 h-1 bg-white rounded-full shadow-[0_0_15px_rgba(255,255,255,1)]"></div>
        </div>

        <!-- Title Section -->
        <div class="flex flex-col items-center gap-4">
            <h1 class="text-white text-xs md:text-sm font-serif font-bold uppercase origin-center animate-title-spread">
                SPOONERGY
            </h1>
            
            <!-- Animated Phrases -->
            <div class="h-4 overflow-hidden relative w-64 flex justify-center mt-2">
                <p id="preloader-phrase" class="text-[9px] text-zinc-400 font-mono tracking-[0.2em] uppercase absolute transition-opacity duration-300">
                    {phrases[0]}
                </p>
            </div>
        </div>

        <!-- Minimal Progress Bar -->
        <div class="w-48 h-[1px] bg-white/5 relative overflow-hidden">
            <div class="absolute top-0 bottom-0 left-0 bg-white/40 animate-progress-fill"></div>
        </div>
    </div>
</div>

<style>
    @keyframes pulse-ring-1 {
        0%, 100% { transform: scale(1); opacity: 0.3; }
        50% { transform: scale(1.2); opacity: 0.6; }
    }
    @keyframes pulse-ring-2 {
        0%, 100% { transform: scale(1.2); opacity: 0.2; }
        50% { transform: scale(1); opacity: 0.4; }
    }
    @keyframes title-spread {
        0% { opacity: 0; letter-spacing: 0.5em; }
        100% { opacity: 1; letter-spacing: 1.2em; }
    }
    @keyframes progress-fill {
        0% { width: 0%; }
        100% { width: 100%; }
    }

    .animate-pulse-ring-1 { animation: pulse-ring-1 2s ease-in-out infinite; }
    .animate-pulse-ring-2 { animation: pulse-ring-2 2.5s ease-in-out infinite; }
    .animate-title-spread { animation: title-spread 2.5s ease-out forwards; }
    .animate-progress-fill { animation: progress-fill 3s ease-in-out forwards; }
</style>

<script is:inline define:vars={{ phrases }}>
    // Bloquear scroll inmediatamente
    document.body.style.overflow = 'hidden';

    const startTime = performance.now();
    let isFinished = false;

    function finishLoader() {
        if (isFinished) return;
        isFinished = true;

        const elapsed = performance.now() - startTime;
        
        // Si la carga fue ultra rápida (ej: < 600ms), saltamos animaciones intermedias
        const isUltraFast = elapsed < 600;
        const delayBeforeOpening = isUltraFast ? 50 : 200;

        setTimeout(() => {
            const topPanel = document.getElementById('preloader-panel-top');
            const bottomPanel = document.getElementById('preloader-panel-bottom');
            const content = document.getElementById('preloader-content');
            const container = document.getElementById('native-preloader');

            if (content) {
                content.style.transition = 'all 0.6s ease-out';
                content.style.opacity = '0';
                content.style.transform = 'scale(1.05)';
            }

            if (topPanel) topPanel.style.transform = 'translateY(-100%)';
            if (bottomPanel) bottomPanel.style.transform = 'translateY(100%)';

            // Restaurar scroll
            document.body.style.overflow = '';

            // Solo tocar audio si el usuario estuvo al menos un segundo esperando (evitar spam sonoro en reloads rápidos)
            if (elapsed > 1200) {
                import('/src/lib/audio.ts').then(module => {
                    if (module.playSound) module.playSound('ethereal');
                }).catch(() => {});
            }

            setTimeout(() => {
                if (container) container.remove();
            }, 1200);
        }, delayBeforeOpening);
    }

    // Ya no esperamos a la pesada carga de la cuchara 3D, ya que la cuchara ahora 
    // requiere interacción del usuario para cargar. Esto prevenía un deadlock de 5 segundos.
    window.addEventListener('load', () => {
        // En cuanto los assets críticos de HTML e imágenes carguen, abrimos.
        finishLoader();
    });

    // Ciclo de frases (solo si no ha terminado ya)
    let phraseIndex = 0;
    const phraseEl = document.getElementById('preloader-phrase');
    const phraseInterval = setInterval(() => {
        if (isFinished || !phraseEl) {
            clearInterval(phraseInterval);
            return;
        }
        phraseIndex = (phraseIndex + 1) % phrases.length;
        phraseEl.style.opacity = '0';
        setTimeout(() => {
            if (isFinished) return;
            phraseEl.textContent = phrases[phraseIndex];
            phraseEl.style.opacity = '1';
        }, 300);
    }, 1200);

    // Fallback de seguridad: Si a los 5 segundos algo catastrófico bloquea load, abrimos.
    setTimeout(() => {
        if (!isFinished) finishLoader();
    }, 5000);
</script>
