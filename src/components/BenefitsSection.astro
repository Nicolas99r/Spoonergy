---
import { VerticalScanGrid } from "./VerticalScanGrid";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
---

<section
    class="w-full flex flex-col justify-start px-10 md:px-32 relative"
>
    <div class="w-full md:w-1/2">
        <VerticalScanGrid client:visible lang={lang} />
    </div>
</section>
