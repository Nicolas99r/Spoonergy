---
import { TextReveal } from "./TextReveal";
---

<section
    id="design"
    class="min-h-[150vh] w-full flex items-center justify-end px-10 md:px-32 relative bg-transparent border-t border-zinc-900/50"
>
    <div
        class="relative z-[60] w-full max-w-2xl text-left md:text-right mt-[30vh] pointer-events-none drop-shadow-lg"
    >
        <h2
            class="text-3xl md:text-5xl font-serif text-zinc-50 tracking-tight leading-snug mb-8"
        >
            Diseñada con intención.
        </h2>
        <TextReveal
            client:visible
            text="Cada curva responde a un propósito. Cada detalle elimina lo innecesario. Su forma no busca llamar la atención. Busca permanecer. No añade nada. No le falta nada."
            className="text-2xl md:text-4xl font-sans font-light text-zinc-300 tracking-tight leading-snug"
        />
    </div>
</section>
