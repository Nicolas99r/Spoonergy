---
import { ui } from "../i18n/ui";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const t = (key: keyof typeof ui["es"]) => ui[lang][key] || ui["es"][key];

const benefits = [
  { title: t('benefits.1.title'), desc: t('benefits.1.desc'), delay: 0 },
  { title: t('benefits.2.title'), desc: t('benefits.2.desc'), delay: 200 },
  { title: t('benefits.3.title'), desc: t('benefits.3.desc'), delay: 400 },
];
---

<div class="w-full relative z-[60] py-24 px-4 overflow-hidden">
    <div class="max-w-7xl mx-auto">
        <h2 class="text-4xl md:text-6xl font-serif text-zinc-50 tracking-tight leading-tight mb-20 reveal-on-scroll">
            {t('benefits.title')}
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 pb-32">
            {benefits.map((benefit) => (
                <div 
                    class="benefit-item flex flex-col gap-6 reveal-on-scroll"
                    style={`--delay: ${benefit.delay}ms`}
                >
                    <div class="h-[1px] w-full bg-gradient-to-r from-zinc-500/50 to-transparent"></div>
                    <h3 class="text-2xl md:text-3xl font-serif text-zinc-100 uppercase tracking-widest">
                        {benefit.title}
                    </h3>
                    <p class="text-lg text-zinc-400 font-light leading-relaxed max-w-sm">
                        {benefit.desc}
                    </p>
                </div>
            ))}
        </div>
    </div>
</div>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0ms);
  }

  .reveal-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
