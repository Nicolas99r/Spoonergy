---
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
    class="min-h-[100vh] w-full flex items-center justify-start px-10 md:px-32 relative bg-transparent"
>
    <div
        class="relative z-[60] w-full max-w-2xl text-left mt-[20vh] pointer-events-none drop-shadow-lg"
    >
        <h2
            class="text-3xl md:text-5xl font-serif text-zinc-50 tracking-tight leading-snug mb-8"
        >
            {t('origen.title')}
        </h2>
        <div
            class="text-lg md:text-xl font-sans font-light text-zinc-400 space-y-6"
        >
            <p>
                {t('origen.p1')}
            </p>
            <p>
                {t('origen.p2')}
            </p>
        </div>
    </div>
</section>
