---
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
    class="min-h-[100vh] w-full flex flex-col items-center justify-center px-10 md:px-32 relative bg-transparent"
>
    <div
        class="relative z-[60] w-full max-w-4xl text-center pointer-events-none drop-shadow-lg"
    >
        <h2
            class="text-4xl md:text-6xl font-serif text-zinc-50 tracking-tight leading-tight mb-12"
        >
            {t('experiencia.title').split('.')[0]}.<br /><span class="text-zinc-400"
                >{t('experiencia.title').split('.')[1]}.</span
            >
        </h2>
        <div
            class="text-lg md:text-2xl font-sans font-light text-zinc-300 max-w-2xl mx-auto space-y-6"
        >
            <p>
                {t('experiencia.p1')}
            </p>
            <p>
                {t('experiencia.p2')}
            </p>
            <p class="text-zinc-500">
                {t('experiencia.p3')}
            </p>
        </div>
    </div>
</section>
